---
import "./styles.css";
import SEO from "@kunyan/astro-blog/components/SEO";
import Nav from "./Nav.astro";
import { createT, createDateFormatter } from "./i18n";
import Footer from "./Footer.astro";
import type { CollectionEntry } from "astro:content";
import type { PageInfo } from "@kunyan/astro-blog/lib/posts";

interface Props {
  posts: CollectionEntry<"posts">[];
  page: PageInfo;
  tag?: string;
  pageUrl: (n: number) => string;
  config: any;
  base: string;
}

const { posts, page, tag, pageUrl, config, base } = Astro.props;
const t = createT(config.site.language);
const formatDate = createDateFormatter(config.site.language);
const heading = tag ? t("posts.tagged", { tag }) : t("posts.all");
---
<html lang={config.site.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO title={`${heading} · ${config.site.title}`} />
  </head>
  <body class="bg-[var(--paper)] text-[var(--text)] font-sans text-base leading-relaxed transition-colors">
    <Nav config={config} base={base} />
    <main class="max-w-4xl mx-auto px-6 pt-10 pb-16 min-h-[calc(100vh-56px-60px)]">
      <h1 class="text-2xl font-semibold mb-5 pb-2 border-b border-[var(--border)] text-[var(--ink)]">{heading}</h1>
      {posts.length === 0 && <p class="text-center py-12 text-[var(--muted)]">{t("posts.empty")}</p>}
      {posts.map((p) => (
        <article class="py-5 border-b border-[var(--border-light)] first:pt-0 last:border-b-0">
          <h3 class="text-xl font-semibold mb-0.5">
            <a href={`${base}/posts/${p.id}`} class="text-[var(--ink)] no-underline hover:text-[var(--accent-hover)] transition-colors">{p.data.title}</a>
          </h3>
          <p class="text-xs text-[var(--muted)]">{formatDate(p.data.pubDate)}</p>
          {p.data.description && <p class="mt-1 text-sm text-[var(--muted)] leading-normal">{p.data.description}</p>}
        </article>
      ))}
      {!tag && page.total > 1 && (
        <nav class="flex items-center justify-center gap-1.5 mt-10 pt-5 border-t border-[var(--border-light)]">
          {page.hasPrev && (
            <a href={pageUrl(page.current - 1)} class="text-sm no-underline w-8 h-8 flex items-center justify-center rounded hover:bg-[var(--border-light)] text-[var(--muted)] transition-colors">&larr;</a>
          )}
          {Array.from({ length: page.total }, (_, i) => i + 1).map((n) => (
            n === page.current ? (
              <span class="text-sm w-8 h-8 flex items-center justify-center rounded bg-[var(--ink)] text-[var(--paper)] font-medium">{n}</span>
            ) : (
              <a href={pageUrl(n)} class="text-sm no-underline w-8 h-8 flex items-center justify-center rounded text-[var(--muted)] hover:bg-[var(--border-light)] transition-colors">{n}</a>
            )
          ))}
          {page.hasNext && (
            <a href={pageUrl(page.current + 1)} class="text-sm no-underline w-8 h-8 flex items-center justify-center rounded hover:bg-[var(--border-light)] text-[var(--muted)] transition-colors">&rarr;</a>
          )}
        </nav>
      )}
    </main>
    <Footer config={config} />
  </body>
</html>
