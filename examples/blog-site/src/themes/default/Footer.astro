---
import { createT } from "./i18n";

interface Props {
  config: any;
}

const { config } = Astro.props;
const t = createT(config.site.language);
const [poweredBefore, poweredAfter] = t("footer.poweredBy", { name: "\0" }).split("\0");
---
<footer class="border-t border-[var(--border-light)] py-5 px-6 text-center text-xs text-[var(--muted)]">
  &copy; {new Date().getFullYear()} {config.site.author || config.site.title} · {poweredBefore}<a href="https://github.com/kunyan/astro-blog" class="text-[var(--muted)] hover:text-[var(--ink)] transition-colors underline">astro-blog</a>{poweredAfter}
</footer>
