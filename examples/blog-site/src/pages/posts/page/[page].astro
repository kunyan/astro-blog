---
import type { GetStaticPaths } from "astro";
import { List } from "@kunyan/astro-blog:current-theme";
import config from "@kunyan/astro-blog:config";
import { getPublishedPosts, paginate } from "@kunyan/astro-blog/lib/posts";

export const getStaticPaths: GetStaticPaths = async () => {
  const isDev = import.meta.env.DEV ?? false;
  const all = await getPublishedPosts({ isDev });
  const total = Math.max(1, Math.ceil(all.length / config.posts.perPage));
  const paths = [];
  for (let n = 2; n <= total; n++) {
    paths.push({ params: { page: String(n) }, props: { pageNum: n } });
  }
  return paths;
};

const { pageNum } = Astro.props as { pageNum: number };
const isDev = import.meta.env.DEV ?? false;
const all = await getPublishedPosts({ isDev });
const { items, page } = paginate(all, pageNum, config.posts.perPage);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

function pageUrl(n: number): string {
  return n === 1 ? `${base}/posts` : `${base}/posts/page/${n}`;
}
---
<List posts={items} page={page} pageUrl={pageUrl} config={config} base={base} />
