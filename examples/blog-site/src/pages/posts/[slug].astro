---
import type { GetStaticPaths } from "astro";
import { Post } from "@kunyan/astro-blog:current-theme";
import config from "@kunyan/astro-blog:config";
import { getPublishedPosts } from "@kunyan/astro-blog/lib/posts";

export const getStaticPaths: GetStaticPaths = async () => {
  const isDev = import.meta.env.DEV ?? false;
  const posts = await getPublishedPosts({ isDev });
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
};

const { post } = Astro.props;
const { Content, headings } = await post.render();
const tocHeadings = headings.filter((h: any) => h.depth >= 2 && h.depth <= 3);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Post post={post} Content={Content} tocHeadings={tocHeadings} config={config} base={base} />
