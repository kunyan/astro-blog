{
  "name": "@kunyan/astro-blog",
  "version": "0.1.1",
  "type": "module",
  "description": "An Astro integration that turns any Astro project into a multi-theme-capable blog.",
  "license": "MIT",
  "author": "Kun Yan<kun.yan@icloud.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:kunyan/astro-blog.git"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./content": "./src/content.ts",
    "./components/SEO": "./src/components/SEO.astro",
    "./lib/posts": "./src/lib/posts.ts",
    "./lib/pages": "./src/lib/pages.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0 || ^6.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tailwindcss/typography": "^0.5.0"
  },
  "devDependencies": {
    "astro": "^5.0.0",
    "vitest": "^2.1.0"
  }
}
