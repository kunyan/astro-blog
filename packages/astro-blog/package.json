{
  "name": "@kunyan/astro-blog",
  "version": "0.1.3",
  "type": "module",
  "description": "An Astro integration that turns any Astro project into a multi-theme-capable blog.",
  "license": "MIT",
  "author": "Kun Yan<kun.yan@icloud.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:kunyan/astro-blog.git"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./content": "./src/content.ts",
    "./components/SEO": "./src/components/SEO.astro",
    "./lib/posts": "./src/lib/posts.ts",
    "./lib/pages": "./src/lib/pages.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "astro": "6.2.2",
    "tailwindcss": "4.2.4",
    "@tailwindcss/vite": "4.2.4",
    "@tailwindcss/typography": "0.5.19"
  },
  "devDependencies": {
    "astro": "6.2.2",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
