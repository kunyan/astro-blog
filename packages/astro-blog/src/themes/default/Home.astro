---
import "./styles.css";
import SEO from "@kunyan/astro-blog/components/SEO";
import Nav from "./Nav.astro";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { createT, createDateFormatter } from "./i18n";
import Footer from "./Footer.astro";

interface Props {
  posts: CollectionEntry<"posts">[];
  hasMore?: boolean;
  config: any;
  base: string;
}

const { posts, hasMore = false, config, base } = Astro.props;
const t = createT(config.site.language);
const formatDate = createDateFormatter(config.site.language);
---
<html lang={config.site.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO />
  </head>
  <body class="bg-[var(--paper)] text-[var(--text)] font-sans text-base leading-relaxed transition-colors">
    <Nav config={config} base={base} />
    {config.site.description && (
      <section class="border-b border-[var(--border-light)] py-16 px-6">
        <p class="max-w-2xl mx-auto text-2xl text-center text-[var(--muted)] leading-relaxed">{config.site.description}</p>
      </section>
    )}
    <main class="max-w-7xl mx-auto px-6 pt-10 pb-16">
      {posts.length === 0 && <p class="text-center py-12 text-[var(--muted)]">{t("posts.empty")}</p>}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((p) => (
          <a href={`${base}/posts/${p.id}`} class="group block no-underline rounded-lg border border-[var(--border-light)] overflow-hidden hover:border-[var(--border)] hover:shadow-lg transition-all duration-300">
            <div class="overflow-hidden aspect-[2/1] bg-[var(--border-light)]">
              {p.data.cover ? (
                <Image
                  src={p.data.cover}
                  alt={p.data.coverAlt || p.data.title}
                  width={600}
                  height={300}
                  class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-110"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-[var(--muted)] text-sm">
                  {p.data.title}
                </div>
              )}
            </div>
            <div class="p-4">
              <p class="text-xs text-[var(--muted)] mb-1">{formatDate(p.data.pubDate)}</p>
              <h2 class="text-lg font-semibold text-[var(--ink)] leading-snug group-hover:text-[var(--accent-hover)] transition-colors">{p.data.title}</h2>
              {p.data.description && <p class="mt-1.5 text-sm text-[var(--muted)] leading-normal line-clamp-2">{p.data.description}</p>}
            </div>
          </a>
        ))}
      </div>
      {hasMore && (
        <div class="mt-10 text-center">
          <a href={`${base}/posts`} class="inline-block text-sm no-underline px-5 py-2 border border-[var(--border)] rounded text-[var(--ink)] hover:bg-[var(--border-light)] transition-colors">
{t("posts.viewAll")}
          </a>
        </div>
      )}
    </main>
    <Footer config={config} />
  </body>
</html>
