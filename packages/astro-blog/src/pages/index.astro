---
import { Home } from "@kunyan/astro-blog:current-theme";
import config from "@kunyan/astro-blog:config";
import { getPublishedPosts } from "@kunyan/astro-blog/lib/posts";

const isDev = import.meta.env.DEV ?? false;
const all = await getPublishedPosts({ isDev });
const posts = all.slice(0, config.posts.perPage);
const hasMore = all.length > config.posts.perPage;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Home posts={posts} hasMore={hasMore} config={config} base={base} />
