---
import { List } from "@kunyan/astro-blog:current-theme";
import config from "@kunyan/astro-blog:config";
import { getPublishedPosts, paginate } from "@kunyan/astro-blog/lib/posts";

const isDev = import.meta.env.DEV ?? false;
const all = await getPublishedPosts({ isDev });
const { items, page } = paginate(all, 1, config.posts.perPage);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

function pageUrl(n: number): string {
  return n === 1 ? `${base}/posts` : `${base}/posts/page/${n}`;
}
---
<List posts={items} page={page} pageUrl={pageUrl} config={config} base={base} />
